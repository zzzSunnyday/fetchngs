nextflow_pipeline {

    name "Test pipeline: PRIDE default"
    script "../../../main.nf"
    tag "pipeline"
    tag "pride"
    profile "test_pride"

    test("Parameters: default") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/**'])
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'workflows/pride/tests/.nftignore')
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    stable_name,
                    stable_path
                ).match() }
            )
        }
    }
}
